{
    "name": "glazyrviz",
    "version": "1.0.0",
    "description": "Zero-Copy MCP Vision Server — sub-8ms browser perception for AI agents. Connect at https://mcp.glazyr.com/mcp/sse",
    "homepage": "https://glazyr.com",
    "repository": "https://github.com/mcpmessenger/glazyr-viz",
    "keywords": [
        "mcp",
        "vision",
        "browser",
        "zero-copy",
        "ai-agent",
        "glazyr"
    ],
    "type": "module",
    "bin": {
        "glazyrviz": "./dist/index.js"
    },
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsc",
        "start": "tsx src/index.ts",
        "start:http": "tsx src/server-http.ts",
        "start:prod": "NODE_ENV=production node dist/index.js",
        "dev": "tsx watch src/index.ts"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "latest",
        "@types/redis": "^4.0.10",
        "@types/uuid": "^10.0.0",
        "@upstash/redis": "^1.36.4",
        "cors": "latest",
        "express": "latest",
        "nats": "^2.29.3",
        "redis": "^5.11.0",
        "uuid": "^13.0.0",
        "viem": "latest",
        "zod": "latest"
    },
    "devDependencies": {
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/node": "^25.5.0",
        "tsx": "latest",
        "typescript": "latest"
    }
}
